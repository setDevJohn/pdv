# Copiar para .env e ajustar conforme o ambiente (local, VPS)

DATABASE_URL=postgresql://pdv:pdv@db:5432/pdv
NODE_ENV=development
VITE_API_URL=http://localhost:3000
WEB_URL=http://localhost:5173

# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Um segredo diferente para cada um — nunca reaproveitar entre access/refresh/gerente,
# e nunca usar os valores de exemplo/dev em produção.
JWT_ACCESS_SECRET=troque-por-um-valor-aleatorio
JWT_REFRESH_SECRET=troque-por-um-valor-aleatorio
JWT_GERENTE_SECRET=troque-por-um-valor-aleatorio
